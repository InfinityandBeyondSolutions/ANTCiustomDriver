<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="10dp"
    android:layout_marginBottom="2dp"
    app:cardCornerRadius="18dp"
    app:cardElevation="6dp"
    app:cardBackgroundColor="@color/white">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <TextView
            android:id="@+id/priceListTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Wholesale Pricelist"
            android:textColor="@color/webnavy"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btnDownloadPdf" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDownloadPdf"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:contentDescription="Download PDF"
            app:icon="@drawable/ic_download_24"
            app:iconTint="@color/webnavy"
            app:iconSize="20dp"
            app:iconPadding="0dp"
            android:padding="0dp"
            android:layout_marginEnd="8dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btnSharePdf"
            app:layout_constraintBottom_toTopOf="@id/priceListSubtitle" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSharePdf"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:contentDescription="Share PDF"
            app:icon="@drawable/ic_share_24"
            app:iconTint="@color/webnavy"
            app:iconSize="20dp"
            app:iconPadding="0dp"
            android:padding="0dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toTopOf="@id/priceListSubtitle" />

        <TextView
            android:id="@+id/priceListSubtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="ACE NUT TRADERS • Effective: 1 July 2025"
            android:textColor="#667788"
            android:textSize="13sp"
            app:layout_constraintTop_toBottomOf="@id/priceListTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/priceListBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_greeting_badge"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:text="active • 120 items"
            android:textColor="@color/webgold"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/priceListSubtitle"
            app:layout_constraintStart_toStartOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
