<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="10dp"
    android:layout_marginBottom="2dp"
    app:cardCornerRadius="18dp"
    app:cardElevation="8dp"
    app:cardBackgroundColor="@android:color/transparent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_order_card"
        android:orientation="vertical"
        android:padding="18dp">

        <!-- Header Row: Order Number + Status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/orderNumber"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Order #12345"
                android:textColor="@color/webnavy"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/orderStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_greeting_badge"
                android:paddingHorizontal="12dp"
                android:paddingVertical="5dp"
                android:text="Pending"
                android:textColor="@color/webgold"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Store Info Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_order_info_badge"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:id="@+id/orderStoreName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Store Name"
                android:textColor="@color/webnavy"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/orderStoreId"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="Store ID"
                android:textColor="#667788"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Bottom Row: Date + Total + View Button -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/orderDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="24 Jun 2025, 15:42"
                    android:textColor="#99AABB"
                    android:textSize="12sp"
                    android:drawableStart="@android:drawable/ic_menu_recent_history"
                    android:drawableTint="#99AABB"
                    android:drawablePadding="4dp" />

                <TextView
                    android:id="@+id/orderTotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_order_total_badge"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="7dp"
                    android:text="R 1,250.00"
                    android:textColor="@color/webnavy"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnViewOrder"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:backgroundTint="@color/webnavy"
                android:text="View Order"
                android:textAllCaps="false"
                android:textColor="@color/webgold"
                android:textSize="14sp"
                android:textStyle="bold"
                app:cornerRadius="12dp"
                app:icon="@drawable/ic_pricelist_table"
                app:iconGravity="textStart"
                app:iconPadding="6dp"
                app:iconTint="@color/webgold" />
        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>

