<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context="com.ibs.ibs_antdrivers.DriverCaptureProductImages">

    <!-- Scrollable main content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:paddingBottom="88dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Compact Header -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/headerCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="@android:color/transparent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_call_cycle_header"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp">

                    <ImageView
                        android:id="@+id/ivBackButton"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:contentDescription="Back"
                        android:padding="6dp"
                        android:src="@drawable/vectorback"
                        app:tint="@color/white" />

                    <TextView
                        android:id="@+id/title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1"
                        android:text="Capture Images"
                        android:textColor="@color/white"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/imageCountBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_badge_navy_outline"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="5dp"
                        android:text="0"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        tools:text="3" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Store Info Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/storeCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#1AD4AF37"
                app:cardBackgroundColor="@android:color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#0A1F44"
                        app:strokeColor="#1AD4AF37"
                        app:strokeWidth="1dp">

                        <TextView
                            android:id="@+id/storeMonogram"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="S"
                            android:textColor="@color/webgold"
                            android:textStyle="bold"
                            android:textSize="15sp" />

                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:id="@+id/tvStoreName"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1"
                        android:text="Store"
                        android:textColor="@color/webnavy"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        tools:text="Acme Store" />

                    <TextView
                        android:id="@+id/storeIdBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_badge_gold"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="5dp"
                        android:text=""
                        android:textAllCaps="true"
                        android:textColor="@color/webnavy"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        tools:text="GN56785" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Icon Action Buttons Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal"
                android:weightSum="2">

                <!-- Gallery Button -->
                <LinearLayout
                    android:id="@+id/btnAddImage"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/bg_icon_action_button_navy"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_gallery"
                        android:contentDescription="Gallery"
                        app:tint="@color/webgold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp"
                        android:text="Gallery"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <!-- Camera Button -->
                <LinearLayout
                    android:id="@+id/btnCaptureImage"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/bg_icon_action_button_navy"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_camera"
                        android:contentDescription="Camera"
                        app:tint="@color/webgold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp"
                        android:text="Camera"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                </LinearLayout>

            </LinearLayout>

            <!-- Selected Photos Section -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/imagesCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#1AD4AF37"
                app:cardBackgroundColor="@android:color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <!-- Section header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:layout_marginBottom="10dp">

                        <TextView
                            android:id="@+id/imagesTitle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Selected Photos"
                            android:textColor="@color/webnavy"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/imagesSubtitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tap ✕ to remove"
                            android:textColor="#6B7280"
                            android:textSize="12sp" />

                    </LinearLayout>

                    <!-- Image grid RecyclerView -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvStoreImages"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="260dp"
                        android:nestedScrollingEnabled="false"
                        android:clipToPadding="false" />

                    <!-- Empty state -->
                    <LinearLayout
                        android:id="@+id/emptyImages"
                        android:layout_width="match_parent"
                        android:layout_height="180dp"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:visibility="gone"
                        tools:visibility="visible">

                        <ImageView
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:src="@drawable/ic_gallery"
                            android:alpha="0.3"
                            app:tint="@color/webnavy"
                            android:contentDescription="No photos" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="No photos yet"
                            android:textColor="#6B7280"
                            android:textSize="13sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Tap Gallery or Camera above to add"
                            android:textColor="#9CA3AF"
                            android:textSize="12sp" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- Floating Upload Action Button -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btnUploadImages"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="20dp"
        android:contentDescription="Upload photos"
        android:src="@drawable/ic_upload_cloud"
        app:backgroundTint="@color/webgold"
        app:tint="@color/webnavy"
        app:fabSize="normal"
        app:elevation="6dp"
        app:pressedTranslationZ="10dp" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
