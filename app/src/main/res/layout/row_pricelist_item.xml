<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rowCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:id="@+id/rowContent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:background="@color/white">

        <TextView
            android:id="@+id/colItemNo"
            android:layout_width="96dp"
            android:layout_height="wrap_content"
            android:textColor="@color/webnavy"
            android:textStyle="bold"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/colDescription"
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:textColor="@color/webnavy"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/colBrand"
            android:layout_width="90dp"
            android:layout_height="wrap_content"
            android:textColor="#667788"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/colSize"
            android:layout_width="90dp"
            android:layout_height="wrap_content"
            android:textColor="#667788"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/colUnitBarcode"
            android:layout_width="150dp"
            android:layout_height="wrap_content"
            android:textColor="#0A1F44"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/colOuterBarcode"
            android:layout_width="160dp"
            android:layout_height="wrap_content"
            android:textColor="#0A1F44"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/colUnitPrice"
            android:layout_width="90dp"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:textColor="#0A1F44"
            android:textStyle="bold"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/colCasePrice"
            android:layout_width="90dp"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:textColor="#0A1F44"
            android:textStyle="bold"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/colId"
            android:layout_width="80dp"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:textColor="#667788"
            android:textSize="12sp" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
